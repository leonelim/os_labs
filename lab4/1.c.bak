#include <fcntl.h>
#include <stdio.h>
#include <stdlib.h>
#include <sys/stat.h>
#include <unistd.h>

int main() {
  for (int i = 0; i < 8; ++i) {
    if (fork() == 0) {
      char name[3];
      sprintf(name, "1%d", i + 2);
      mkfifo(name, 0666);
      int fd = open(name, O_WRONLY);
      write(fd, name, 3);
      close(fd);
      exit(0);
    }
  }
  for (int i = 0; i < 8; ++i) {
    if (fork() == 0) {
      char name[3];
      int fd = open(name, O_RDONLY);
      read(fd, name, 3);
      puts(name);
      close(fd);
      exit(0);
    }
  }
  return 0;
}
